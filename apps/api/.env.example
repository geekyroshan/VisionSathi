# VisionSathi API - Environment Variables
# Copy this file to .env and configure for your environment

# Server settings
DEBUG=false
PORT=8000

# CORS - Add your mobile app's production URL
CORS_ORIGINS=["http://localhost:8081","exp://localhost:8081","https://your-production-domain.com"]

# Model settings
MOONDREAM_MODEL=vikhyatk/moondream2
MOONDREAM_DEVICE=cpu
MOONDREAM_DTYPE=float32
PRELOAD_MODEL=true

# Cache
CACHE_ENABLED=true
CACHE_TTL=3600

# Rate limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60
