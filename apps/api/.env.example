# VisionSathi API - Environment Variables
# Copy this file to .env and configure for your environment

# Server settings
DEBUG=false
PORT=8000

# CORS - Add your mobile app's production URL
CORS_ORIGINS=["http://localhost:8081","exp://localhost:8081","https://your-production-domain.com"]

# Ollama settings
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=moondream

# OpenAI fallback (used when Moondream/Ollama is unavailable)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o

# Cache
CACHE_ENABLED=true
CACHE_TTL=3600

# Rate limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60
